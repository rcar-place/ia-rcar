# ───────────────────────────────────────────────
# ML AutoResponder — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais!
# ───────────────────────────────────────────────

# Aplicação
APP_NAME="ML AutoResponder"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Servidor
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Banco de Dados MySQL
# Formato: mysql+aiomysql://usuario:senha@host:porta/database
DATABASE_URL=mysql+aiomysql://ml_user:SENHA_FORTE_AQUI@localhost:3306/ml_autoresponder
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Segurança JWT
# Gere com: openssl rand -hex 32
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_FORTE_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.com

# Mercado Livre
ML_CLIENT_ID=SEU_ML_CLIENT_ID
ML_CLIENT_SECRET=SEU_ML_CLIENT_SECRET
ML_ACCESS_TOKEN=SEU_ML_ACCESS_TOKEN
ML_REFRESH_TOKEN=SEU_ML_REFRESH_TOKEN
ML_WEBHOOK_SECRET=SEU_ML_WEBHOOK_SECRET
ML_SELLER_ID=SEU_ML_SELLER_ID
ML_BASE_URL=https://api.mercadolibre.com

# OpenAI
OPENAI_API_KEY=sk-SUA_CHAVE_OPENAI_AQUI
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300
OPENAI_TEMPERATURE=0.3

# Horário Comercial (America/Sao_Paulo)
BUSINESS_HOUR_START=8
BUSINESS_HOUR_END=18
TIMEZONE=America/Sao_Paulo

# Rate Limiting
RATE_LIMIT_WEBHOOK=100/minute
RATE_LIMIT_API=200/minute

# Redis (opcional, para rate limiting distribuído)
REDIS_URL=redis://localhost:6379/0
